// نظام الضيــــــــــاء - إدارة محطات الوقود
// قاعدة بيانات شاملة ومتكاملة

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== المستخدمين والصلاحيات ====================

model User {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  password      String
  role          String   @default("user") // admin, manager, user
  avatar        String?
  branchIds     String?  // فروع متعددة مفصولة بفواصل
  permissions   Permission?
  settings      Json?    // إعدادات المستخدم (حجم الجداول، إلخ)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  branch               Branch?           @relation(fields: [branchId], references: [id])
  branchId             String?
  salesInvoices        SaleInvoice[]
  purchaseInvoices     PurchaseInvoice[]
  paymentVouchers      PaymentVoucher[]
  paymentDisbursements PaymentDisbursement[]
  expenses             Expense[]
  inventoryCounts      InventoryCount[]
  inventoryAdjustments InventoryAdjustment[]
  warehouseTransfers   WarehouseTransfer[]
  purchaseReturns      PurchaseReturn[]
}

model Permission {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // صلاحيات البيع
  canSale                 Boolean  @default(true)
  canChangePrice          Boolean  @default(false)
  canCreditSale           Boolean  @default(true)
  canViewPurchasePrice    Boolean  @default(false)
  canEditSaleInvoice      Boolean  @default(false)
  canDeleteSaleInvoice    Boolean  @default(false)
  canEditSaleDate         Boolean  @default(false)
  canGiveFreeWash         Boolean  @default(false)
  canPartialPayment       Boolean  @default(true)
  
  // صلاحيات الشراء
  canPurchase             Boolean  @default(true)
  canEditPurchaseInvoice  Boolean  @default(false)
  canDeletePurchaseInvoice Boolean @default(false)
  canPurchaseReturn       Boolean  @default(false)
  
  // صلاحيات المخازن
  canViewMaterials        Boolean  @default(true)
  canEditMaterial         Boolean  @default(false)
  canDeleteMaterial       Boolean  @default(false)
  canAddMaterial          Boolean  @default(false)
  canWarehouseTransfer    Boolean  @default(false)
  canTransferBetweenBranches Boolean @default(false)
  canTransferBetweenWarehouses Boolean @default(false)
  canInventoryCount       Boolean  @default(false)
  canInventoryAdjustment  Boolean  @default(false)
  
  // صلاحيات الحسابات
  canViewAccounts         Boolean  @default(true)
  canEditCustomer         Boolean  @default(false)
  canEditSupplier         Boolean  @default(false)
  canPaymentVoucher       Boolean  @default(false)
  canPaymentDisbursement  Boolean  @default(false)
  canExpense              Boolean  @default(false)
  
  // صلاحيات الإعدادات
  canViewSettings         Boolean  @default(false)
  canAddUser              Boolean  @default(false)
  canEditUser             Boolean  @default(false)
  canAddWarehouse         Boolean  @default(false)
  canBackup               Boolean  @default(false)
  
  // صلاحيات التقارير
  canViewReports          Boolean  @default(true)
  canViewAccountStatement Boolean  @default(true)
  canViewSalesReport      Boolean  @default(true)
  canViewPurchasesReport  Boolean  @default(true)
  canViewDailyMatching    Boolean  @default(true)
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ==================== الفروع والمخازن ====================

model Branch {
  id          String      @id @default(cuid())
  name        String
  address     String?
  phone       String?
  warehouses  Warehouse[]
  users       User[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Warehouse {
  id               String             @id @default(cuid())
  name             String
  branchId         String
  branch           Branch             @relation(fields: [branchId], references: [id])
  isDefault        Boolean            @default(false)
  materials        Material[]
  saleItems        SaleItem[]
  purchaseItems    PurchaseItem[]
  inventoryCounts  InventoryCount[]
  adjustments      InventoryAdjustment[]
  transfersFrom    WarehouseTransfer[] @relation("TransferFrom")
  transfersTo      WarehouseTransfer[] @relation("TransferTo")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

// ==================== المواد والفئات ====================

model Category {
  id          String     @id @default(cuid())
  name        String
  type        String     @default("material") // material, service
  materials   Material[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Material {
  id               String              @id @default(cuid())
  name             String
  code             String?
  categoryId       String?
  category         Category?           @relation(fields: [categoryId], references: [id])
  
  // نظام التعبئة الهرمي
  unit             String              @default("قطعة")
  baseUnit         String              @default("قطعة")
  fillingType      String              @default("single") // single, multi
  
  // المستوى الأول (الأكبر) - مثال: كارتون
  level1Name       String?
  level1Quantity   Float?
  level1SalePrice  Float?              // سعر بيع الكارتون
  
  // المستوى الثاني - مثال: سيت
  level2Name       String?
  level2Quantity   Float?
  level2SalePrice  Float?              // سعر بيع السيت
  
  // المستوى الثالث - مثال: درزن
  level3Name       String?
  level3Quantity   Float?
  level3SalePrice  Float?              // سعر بيع الدرزن
  
  // الأسعار والكميات
  purchasePrice    Float               @default(0)         // سعر الشراء للوحدة الأساسية
  salePrice        Float               @default(0)         // سعر البيع للوحدة الأساسية
  quantity         Float               @default(0)
  minQuantity      Float               @default(0)
  
  warehouseId      String?
  warehouse        Warehouse?          @relation(fields: [warehouseId], references: [id])
  
  saleItems        SaleItem[]
  purchaseItems    PurchaseItem[]
  transferItems    TransferItem[]
  returnItems      PurchaseReturnItem[]
  inventoryItems   InventoryItem[]
  adjustmentItems  AdjustmentItem[]
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

// ==================== الزبائن والموردين ====================

model Customer {
  id              String      @id @default(cuid())
  name            String
  phone           String?
  address         String?
  carNumber       String?
  carType         String?
  odometer        Int?
  lastOdometer    Int?
  type            String      @default("customer") // customer, supplier, both
  
  invoices        SaleInvoice[]
  coupons         FreeWashCoupon[]
  paymentVouchers PaymentVoucher[]
  paymentDisbursements PaymentDisbursement[]
  accounts        AccountBalance[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ==================== المبيعات ====================

model SaleInvoice {
  id             String      @id @default(cuid())
  invoiceNumber  String      @default(cuid())
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  warehouseId    String?
  items          SaleItem[]
  
  subtotal       Float       @default(0)
  discount       Float       @default(0)
  total          Float       @default(0)
  paid           Float       @default(0)
  remaining      Float       @default(0)
  status         String      @default("cash") // cash, credit, partial
  
  odometer       Int?
  notes          String?
  
  editedCount    Int         @default(0)
  editHistory    Json?
  isEdited        Boolean     @default(false)
  editedAt       DateTime?
  
  createdBy      String?
  user           User?       @relation(fields: [createdBy], references: [id])
  branchId       String?
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model SaleItem {
  id            String      @id @default(cuid())
  invoiceId     String
  invoice       SaleInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  materialId    String
  material      Material    @relation(fields: [materialId], references: [id])
  materialName  String
  
  quantity      Float       @default(0)
  price         Float       @default(0)
  total         Float       @default(0)
  
  filling       String?
  notes         String?
  warehouseId   String?
  warehouse     Warehouse?  @relation(fields: [warehouseId], references: [id])
  
  createdAt     DateTime    @default(now())
}

// ==================== المشتريات ====================

model PurchaseInvoice {
  id             String           @id @default(cuid())
  invoiceNumber  String           @default(cuid())
  supplierId     String?
  supplierName   String?
  warehouseId    String?
  items          PurchaseItem[]
  
  subtotal       Float            @default(0)
  discount       Float            @default(0)
  total          Float            @default(0)
  paid           Float            @default(0)
  remaining      Float            @default(0)
  status         String           @default("cash")
  
  notes          String?
  editedCount    Int              @default(0)
  editHistory    Json?
  
  createdBy      String?
  user           User?            @relation(fields: [createdBy], references: [id])
  branchId       String?
  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PurchaseItem {
  id            String           @id @default(cuid())
  invoiceId     String
  invoice       PurchaseInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  materialId    String
  material      Material         @relation(fields: [materialId], references: [id])
  materialName  String
  
  quantity      Float            @default(0)
  price         Float            @default(0)
  total         Float            @default(0)
  
  notes         String?
  warehouseId   String?
  warehouse     Warehouse?       @relation(fields: [warehouseId], references: [id])
  
  createdAt     DateTime         @default(now())
}

model PurchaseReturn {
  id             String              @id @default(cuid())
  returnNumber   String              @default(cuid())
  purchaseId     String?
  supplierName   String?
  warehouseId    String?
  items          PurchaseReturnItem[]
  
  total          Float               @default(0)
  notes          String?
  
  createdBy      String?
  user           User?               @relation(fields: [createdBy], references: [id])
  
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model PurchaseReturnItem {
  id            String         @id @default(cuid())
  returnId      String
  returnInvoice PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  
  materialId    String
  material      Material       @relation(fields: [materialId], references: [id])
  materialName  String
  
  quantity      Float          @default(0)
  price         Float          @default(0)
  total         Float          @default(0)
  
  notes         String?
  
  createdAt     DateTime       @default(now())
}

// ==================== النقل المخزني ====================

model WarehouseTransfer {
  id               String         @id @default(cuid())
  transferNumber   String         @default(cuid())
  
  fromWarehouseId  String
  fromWarehouse    Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId    String
  toWarehouse      Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  
  items            TransferItem[]
  notes            String?
  
  editedCount      Int            @default(0)
  editHistory      Json?
  
  createdBy        String?
  user             User?          @relation(fields: [createdBy], references: [id])
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TransferItem {
  id            String            @id @default(cuid())
  transferId    String
  transfer      WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  
  materialId    String
  material      Material          @relation(fields: [materialId], references: [id])
  materialName  String
  
  quantity      Float             @default(0)
  notes         String?
  
  createdAt     DateTime          @default(now())
}

// ==================== الجرد والتسوية ====================

model InventoryCount {
  id            String           @id @default(cuid())
  countNumber   String           @default(cuid())
  warehouseId   String
  warehouse     Warehouse        @relation(fields: [warehouseId], references: [id])
  
  items         InventoryItem[]
  status        String           @default("draft") // draft, completed
  
  notes         String?
  createdBy     String?
  user          User?            @relation(fields: [createdBy], references: [id])
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model InventoryItem {
  id              String         @id @default(cuid())
  countId         String?
  count           InventoryCount? @relation(fields: [countId], references: [id], onDelete: Cascade)
  
  materialId      String
  material        Material       @relation(fields: [materialId], references: [id])
  materialName    String
  
  systemQuantity  Float          @default(0)
  actualQuantity  Float          @default(0)
  difference      Float          @default(0)
  
  notes           String?
  
  createdAt       DateTime       @default(now())
}

model InventoryAdjustment {
  id               String           @id @default(cuid())
  adjustmentNumber String           @default(cuid())
  warehouseId      String
  warehouse        Warehouse        @relation(fields: [warehouseId], references: [id])
  
  items            AdjustmentItem[]
  notes            String?
  
  createdBy        String?
  user             User?            @relation(fields: [createdBy], references: [id])
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model AdjustmentItem {
  id              String              @id @default(cuid())
  adjustmentId    String
  adjustment      InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  
  materialId      String
  material        Material            @relation(fields: [materialId], references: [id])
  materialName    String
  
  systemQuantity  Float               @default(0)
  actualQuantity  Float               @default(0)
  difference      Float               @default(0)
  
  notes           String?
  
  createdAt       DateTime            @default(now())
}

// ==================== السندات والمصروفات ====================

model PaymentVoucher {
  id            String    @id @default(cuid())
  voucherNumber String    @default(cuid())
  
  amount        Float     @default(0)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  userId        String?   // للموظفين
  payerType     String    @default("customer") // customer, supplier, employee, other
  
  paymentMethod String    @default("cash")
  notes         String?
  createdBy     String?
  user          User?     @relation(fields: [createdBy], references: [id])
  branchId      String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PaymentDisbursement {
  id                  String    @id @default(cuid())
  voucherNumber       String    @default(cuid())
  
  amount              Float     @default(0)
  supplierId          String?   // معرف المورد (من جدول Customer حيث type=supplier)
  customerId          String?
  customer            Customer? @relation(fields: [customerId], references: [id])
  userId              String?   // للموظفين
  payeeType           String    @default("supplier") // supplier, customer, employee, expense, other
  employeePaymentType String?   // للموظفين: salary, advance, bonus, deduction, other
  
  paymentMethod       String    @default("cash")
  notes               String?
  createdBy           String?
  user                User?     @relation(fields: [createdBy], references: [id])
  branchId            String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Expense {
  id           String   @id @default(cuid())
  voucherNumber String  @default(cuid())
  
  description  String
  amount       Float    @default(0)
  category     String?
  
  // حقول صرف رواتب الموظفين
  expenseType        String?   @default("general") // general, employee
  userId             String?   // للموظف المستلم
  employeePaymentType String?  // salary, advance, bonus, deduction, other
  
  branchId     String?
  notes        String?
  
  createdBy    String?
  user         User?    @relation(fields: [createdBy], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== أرصدة الحسابات ====================

model AccountBalance {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  branchId     String?
  
  debit        Float     @default(0)  // مديون
  credit       Float     @default(0)  // دائن
  balance      Float     @default(0)  // الرصيد
  
  lastUpdated  DateTime  @default(now())
}

// ==================== الغسل المجاني ====================

model FreeWashCoupon {
  id          String     @id @default(cuid())
  couponCode  String     @default(cuid())
  
  customerName  String?
  phone       String
  carNumber   String
  carType     String?
  
  branchId    String?
  
  expiresAt   DateTime
  used        Boolean    @default(false)
  usedAt      DateTime?
  
  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  invoiceId   String?
  
  createdBy   String?
  
  createdAt   DateTime   @default(now())
}

// ==================== القاصة والمطابقة ====================

model CashRegister {
  id          String           @id @default(cuid())
  branchId    String
  
  balance     Float            @default(0)
  transactions CashTransaction[]
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CashTransaction {
  id            String        @id @default(cuid())
  registerId    String
  register      CashRegister  @relation(fields: [registerId], references: [id])
  
  type          String    // in, out
  amount        Float     @default(0)
  description   String?
  
  referenceType String?   // sale, purchase, voucher, etc.
  referenceId   String?
  
  createdAt     DateTime  @default(now())
}

model DailyMatching {
  id                String    @id @default(cuid())
  branchId          String
  date              DateTime
  
  cashSales         Float     @default(0)
  creditSales       Float     @default(0)
  partialSales      Float     @default(0)
  cashPurchases     Float     @default(0)
  creditPurchases   Float     @default(0)
  expenses          Float     @default(0)
  vouchersIn        Float     @default(0)
  vouchersOut       Float     @default(0)
  
  total             Float     @default(0)
  
  notes             String?
  createdBy         String?
  
  createdAt         DateTime  @default(now())
}

// ==================== الإعدادات والنسخ الاحتياطي ====================

model Setting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BackupLog {
  id          String    @id @default(cuid())
  type        String    // download, upload, whatsapp
  fileName    String?
  fileSize    Float?
  status      String    @default("success")
  
  createdBy   String?
  
  createdAt   DateTime  @default(now())
}
